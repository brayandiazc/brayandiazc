# EditorConfig — https://editorconfig.org
# Mantiene un formato consistente del Markdown entre editores.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# El Markdown usa dos espacios finales para forzar saltos de línea: no los recortes.
trim_trailing_whitespace = false
